.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.section {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.suit-label {
  font-weight: 500;
}

.suit-m { color: #2d8cf0; }
.suit-p { color: #e74c3c; }
.suit-s { color: #19be6b; }
.suit-z { color: #6c5ce7; }

.clear-btn {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 4rpx 16rpx;
}

.selected-tiles {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  min-height: 80rpx;
}

.selected-tile {
  position: relative;
}

.tile-text {
  display: inline-block;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: #f0f0f0;
}

.tile-m { color: #2d8cf0; background: #e8f4fd; }
.tile-p { color: #e74c3c; background: #fde8e8; }
.tile-s { color: #19be6b; background: #e8fdf0; }
.tile-z { color: #6c5ce7; background: #f0e8fd; }

.empty-hint {
  text-align: center;
  padding: 30rpx 0;
  color: #ccc;
  font-size: 26rpx;
}

.melds-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meld-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.meld-type-tag {
  font-size: 22rpx;
  color: #fff;
  background: #1a1a2e;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 8rpx;
}

.meld-buffer {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #fffbe6;
  border-radius: 8rpx;
  border: 1rpx solid #ffe58f;
}

.meld-buffer-hint {
  font-size: 24rpx;
  color: #d48806;
  display: block;
  margin-bottom: 8rpx;
}

.meld-actions {
  margin-top: 8rpx;
}

.cancel-btn {
  font-size: 24rpx;
  color: #e74c3c;
  padding: 4rpx 16rpx;
}

.meld-add-btns {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.meld-add-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #333;
  border: 1rpx solid #ddd;
}

.meld-add-btn:active {
  background: #e0e0e0;
}

.mode-switch {
  margin-bottom: 24rpx;
}

.active-dora {
  background: #e74c3c !important;
  color: #fff !important;
}

.tile-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tile-btn {
  width: calc((100% - 96rpx) / 9);
  min-width: 0;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #f8f8f8;
  border: 1rpx solid #eee;
}

.tile-btn:active {
  opacity: 0.6;
}

.tile-m { background: #e8f4fd; color: #2d8cf0; border-color: #d0e8f8; }
.tile-p { background: #fde8e8; color: #e74c3c; border-color: #f8d0d0; }
.tile-s { background: #e8fdf0; color: #19be6b; border-color: #d0f8e0; }
.tile-z { background: #f0e8fd; color: #6c5ce7; border-color: #e0d0f8; }

.conditions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.condition-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.condition-label {
  font-size: 26rpx;
  color: #333;
  width: 120rpx;
  flex-shrink: 0;
}

.toggle-group {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.toggle-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #f5f5f5;
  color: #666;
}

.toggle-btn.active {
  background: #1a1a2e;
  color: #fff;
}

.calc-btn {
  width: 100%;
  background: #1a1a2e;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  margin: 24rpx 0;
  border: none;
}

.calc-btn[disabled] {
  background: #ccc;
  color: #fff;
}

.result {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.result-section {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-section:last-child {
  border-bottom: none;
}

.result-title {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.yaku-item {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 28rpx;
}

.yaku-han {
  color: #e74c3c;
  font-weight: 500;
}

.total-score {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.error {
  background: #fee;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  color: #e74c3c;
  text-align: center;
  font-size: 26rpx;
}
