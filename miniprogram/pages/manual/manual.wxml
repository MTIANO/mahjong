<view class="container">
  <!-- 已选手牌 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">手牌 ({{selectedTiles.length}}/{{14 - melds.length * 3}})</text>
      <text class="clear-btn" bindtap="clearTiles" wx:if="{{selectedTiles.length > 0 || melds.length > 0}}">清空</text>
    </view>
    <view class="selected-tiles" wx:if="{{selectedTiles.length > 0}}">
      <view class="selected-tile" wx:for="{{selectedTiles}}" wx:key="index"
        data-index="{{index}}" bindtap="removeTile">
        <text class="tile-text tile-{{item[1]}}">{{tileNames[item]}}</text>
      </view>
    </view>
    <view class="empty-hint" wx:else>
      <text>点击下方麻将牌添加手牌</text>
    </view>
  </view>

  <!-- 副露区域 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">副露 ({{melds.length}}/4)</text>
    </view>
    <view class="melds-list" wx:if="{{melds.length > 0}}">
      <view class="meld-item" wx:for="{{melds}}" wx:key="index"
        data-index="{{index}}" bindtap="removeMeld">
        <text class="meld-type-tag">{{meldTypeNames[item.type]}}</text>
        <text class="tile-text tile-{{t[1]}}" wx:for="{{item.tiles}}" wx:for-item="t" wx:key="*this">{{tileNames[t]}}</text>
      </view>
    </view>
    <!-- 正在选副露牌 -->
    <view class="meld-buffer" wx:if="{{selectMode === 'meld'}}">
      <text class="meld-buffer-hint">正在选{{meldTypeNames[meldType]}}的牌 ({{meldBuffer.length}}/{{meldType === 'open_kan' || meldType === 'closed_kan' ? 4 : 3}})</text>
      <view class="selected-tiles" wx:if="{{meldBuffer.length > 0}}">
        <text class="tile-text tile-{{t[1]}}" wx:for="{{meldBuffer}}" wx:for-item="t" wx:key="index">{{tileNames[t]}}</text>
      </view>
      <view class="meld-actions">
        <text class="cancel-btn" bindtap="cancelMeld">取消</text>
      </view>
    </view>
    <!-- 添加副露按钮 -->
    <view class="meld-add-btns" wx:if="{{selectMode !== 'meld' && melds.length < 4}}">
      <view class="meld-add-btn" data-type="chi" bindtap="startMeld">+吃</view>
      <view class="meld-add-btn" data-type="pon" bindtap="startMeld">+碰</view>
      <view class="meld-add-btn" data-type="open_kan" bindtap="startMeld">+明杠</view>
      <view class="meld-add-btn" data-type="closed_kan" bindtap="startMeld">+暗杠</view>
    </view>
  </view>

  <!-- 宝牌 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">宝牌 ({{doraTiles.length}}/5)</text>
    </view>
    <view class="selected-tiles" wx:if="{{doraTiles.length > 0}}">
      <view class="selected-tile" wx:for="{{doraTiles}}" wx:key="index"
        data-index="{{index}}" bindtap="removeDora">
        <text class="tile-text tile-{{item[1]}}">{{tileNames[item]}}</text>
      </view>
    </view>
    <view class="empty-hint" wx:else>
      <text>切换到宝牌模式后点击牌添加</text>
    </view>
  </view>

  <!-- 选牌模式切换 -->
  <view class="mode-switch">
    <view class="toggle-group">
      <view class="toggle-btn {{selectMode === 'hand' ? 'active' : ''}}" data-mode="hand" bindtap="setSelectMode">选手牌</view>
      <view class="toggle-btn {{selectMode === 'dora' ? 'active-dora' : ''}}" data-mode="dora" bindtap="setSelectMode">选宝牌</view>
    </view>
  </view>

  <!-- 牌选择区 -->
  <view class="section">
    <text class="section-title suit-label suit-m">万子</text>
    <view class="tile-grid">
      <view class="tile-btn tile-m" wx:for="{{manTiles}}" wx:key="*this"
        data-tile="{{item}}" bindtap="addTile">
        <text>{{tileNames[item]}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title suit-label suit-p">筒子</text>
    <view class="tile-grid">
      <view class="tile-btn tile-p" wx:for="{{pinTiles}}" wx:key="*this"
        data-tile="{{item}}" bindtap="addTile">
        <text>{{tileNames[item]}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title suit-label suit-s">索子</text>
    <view class="tile-grid">
      <view class="tile-btn tile-s" wx:for="{{souTiles}}" wx:key="*this"
        data-tile="{{item}}" bindtap="addTile">
        <text>{{tileNames[item]}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title suit-label suit-z">字牌</text>
    <view class="tile-grid">
      <view class="tile-btn tile-z" wx:for="{{honorTiles}}" wx:key="*this"
        data-tile="{{item}}" bindtap="addTile">
        <text>{{tileNames[item]}}</text>
      </view>
    </view>
  </view>

  <!-- 和牌条件 -->
  <view class="section">
    <text class="section-title">和牌条件</text>
    <view class="conditions">
      <view class="condition-row">
        <text class="condition-label">和牌方式</text>
        <view class="toggle-group">
          <view class="toggle-btn {{isTsumo ? 'active' : ''}}" bindtap="toggleTsumo">自摸</view>
          <view class="toggle-btn {{!isTsumo ? 'active' : ''}}" bindtap="toggleTsumo">荣和</view>
        </view>
      </view>
      <view class="condition-row">
        <text class="condition-label">庄/闲</text>
        <view class="toggle-group">
          <view class="toggle-btn {{isParent ? 'active' : ''}}" bindtap="toggleParent">庄家</view>
          <view class="toggle-btn {{!isParent ? 'active' : ''}}" bindtap="toggleParent">闲家</view>
        </view>
      </view>
      <view class="condition-row">
        <text class="condition-label">自风</text>
        <view class="toggle-group">
          <view class="toggle-btn {{seatWind === index ? 'active' : ''}}"
            wx:for="{{winds}}" wx:key="index"
            data-wind="{{index}}" bindtap="setSeatWind">{{item}}</view>
        </view>
      </view>
      <view class="condition-row">
        <text class="condition-label">场风</text>
        <view class="toggle-group">
          <view class="toggle-btn {{roundWind === index ? 'active' : ''}}"
            wx:for="{{winds}}" wx:key="index"
            data-wind="{{index}}" bindtap="setRoundWind">{{item}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 计算按钮 -->
  <button class="calc-btn" bindtap="calculate" loading="{{loading}}"
    disabled="{{selectedTiles.length < (14 - melds.length * 3 - 1)}}">
    计算番型
  </button>

  <!-- 结果展示 -->
  <view class="result" wx:if="{{result}}">
    <view class="result-section" wx:if="{{result.yaku.length > 0}}">
      <text class="result-title">番型</text>
      <view class="yaku-item" wx:for="{{result.yaku}}" wx:key="name">
        <text>{{item.name}}</text>
        <text class="yaku-han">{{item.han}}番</text>
      </view>
    </view>
    <view class="result-section" wx:if="{{result.yaku.length === 0}}">
      <text class="result-title">无役，不能和牌</text>
    </view>
    <view class="result-section" wx:if="{{result.total_han > 0}}">
      <text class="result-title">得分</text>
      <text class="total-score" wx:if="{{!isTsumo}}">{{result.total_han}}番 — {{result.score.RonTotal}}点</text>
      <text class="total-score" wx:if="{{isTsumo}}">{{result.total_han}}番 — {{result.score.TsumoTotal}}点</text>
      <text class="score-detail" wx:if="{{isTsumo && isParent}}">({{result.score.TsumoFromChild}}点×3家)</text>
      <text class="score-detail" wx:if="{{isTsumo && !isParent}}">(庄家{{result.score.TsumoFromParent}}点 + 闲家{{result.score.TsumoFromChild}}点×2)</text>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="error" wx:if="{{error}}">
    <text>{{error}}</text>
  </view>
</view>
